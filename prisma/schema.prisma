// Perfectionails — Prisma schema
// Database: PostgreSQL (Neon serverless — free tier)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Admin user — single account for the shop owner ─────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash
  name      String?
  createdAt DateTime @default(now())
}

// ── Blog post ───────────────────────────────────────────────────────────────
model Post {
  id          String    @id @default(cuid())
  slug        String    @unique  // URL-friendly identifier, auto-generated from title
  title       String
  excerpt     String
  content     String    @db.Text // Rich HTML from Tiptap WYSIWYG editor
  coverImage  String?             // URL to cover photo
  category    String              // "Trends" | "Care" | "Before & After" | "Camp Hill"
  tags        String[]            // SEO keyword tags
  readTime    String              // e.g. "5 min read"
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Optional SEO overrides (fallback to title/excerpt when empty)
  metaTitle       String?
  metaDescription String?
}

// ── Newsletter subscribers ──────────────────────────────────────────────────
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
}

// ── Contact form enquiries ──────────────────────────────────────────────────
model Enquiry {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  service   String?
  day       String?
  message   String?
  createdAt DateTime @default(now())
  read      Boolean  @default(false)
}
